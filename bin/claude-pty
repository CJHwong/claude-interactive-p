#!/usr/bin/env bash
# claude-pty: run one Claude turn and emit a JSON envelope on stdout when it
# finishes. Two backends, chosen at runtime (see "Backend selection" below):
#   - tmux:       attachable interactive TUI; envelope built from the Stop hook
#                 + statusline shim. The only mode with the statusline subtree.
#   - subprocess: headless `claude -p --output-format=json`, normalized to the
#                 same envelope shape (statusline null). Not attachable.
#
# Envelope shape: superset of `claude -p --output-format=json`. The tmux backend
# adds statusline-exclusive fields (rate_limits, context_window, etc); the
# subprocess backend sources the core fields from -p directly.
#
# Usage:
#   claude-pty [claude flags...] "prompt"
#
# Reads the same Claude Code config as `claude` itself: default ~/.claude, or
# override via CLAUDE_CONFIG_DIR. For the tmux backend the Stop hook and
# statusline shim must already be wired into that config (run install.sh once).
set -euo pipefail

# A claude-pty call only makes sense when there is something for claude to
# auto-submit. Without a prompt, the TUI launches and sits idle waiting on
# stdin that never arrives, and the Stop hook never fires. Reject early.
if [ "$#" -eq 0 ]; then
  echo "claude-pty: missing prompt" >&2
  echo "Usage: claude-pty [claude flags...] \"prompt\"" >&2
  exit 2
fi

# Info-only flags: hand them straight to claude (no PTY, no envelope). claude
# prints its own output and exits cleanly, which is what the user asked for.
# --bare: explicitly incompatible. From claude's own help: "skip hooks, LSP,
# plugin sync...". No hooks means the Stop hook can't fire, which means we'd
# hang forever waiting for an envelope that never lands.
for arg in "$@"; do
  case "$arg" in
    --help|-h|--version|-v)
      exec claude "$@"
      ;;
    --bare)
      echo "claude-pty: --bare disables claude's hook system, which we" >&2
      echo "           depend on. Run claude directly instead, or drop --bare." >&2
      exit 2
      ;;
  esac
done

# If the last arg starts with `-`, it's a flag with no prompt after it, which
# would launch the TUI with nothing to auto-submit (the `--bare` case). This
# heuristic doesn't catch a flag-that-takes-a-value as the last arg (e.g.
# `--model haiku` with no prompt would still hang), but it covers the common
# slip. A real fix would require knowing claude's full flag spec.
last_arg="${!#}"
case "$last_arg" in
  -*)
    echo "claude-pty: last argument is a flag ($last_arg), not a prompt" >&2
    echo "Usage: claude-pty [claude flags...] \"prompt\"" >&2
    exit 2
    ;;
esac

tmp_dir=$(mktemp -d -t claude-pty.XXXXXX)
lock_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/.pty-lock"
release_pid=""
# Cleanup releases our lock only if it's still ours — once the early-release
# watcher hands the lock off to a sibling, that sibling's PID is in
# $lock_dir/pid and we must not blow it away on our EXIT.
cleanup() {
  rm -rf "$tmp_dir" 2>/dev/null || true
  if [ -n "$release_pid" ]; then
    kill "$release_pid" 2>/dev/null || true
    wait "$release_pid" 2>/dev/null || true
  fi
  if [ -d "$lock_dir" ]; then
    local holder=""
    holder=$(cat "$lock_dir/pid" 2>/dev/null || true)
    if [ "$holder" = "$$" ]; then
      rm -rf "$lock_dir" 2>/dev/null || true
    fi
  fi
}
trap cleanup EXIT

export CLAUDE_PTY_ENVELOPE="$tmp_dir/envelope.json"
export CLAUDE_PTY_SIDECAR="$tmp_dir/sidecar.json"
export CLAUDE_PTY_DEBUG_LOG="${CLAUDE_PTY_DEBUG_LOG:-$tmp_dir/debug.log}"

# Serialize ONLY claude's supervisor startup race. Claude's TUI mode races
# on a singleton supervisor lock during the first ~1s of boot; two TUIs
# starting simultaneously leave one (or both) hung. Once a claude is past
# that window, additional claudes can run in parallel without conflict.
# So we acquire a mkdir-based lock to gate startup, then release it as
# soon as our claude reaches steady state — signalled by the statusline
# shim writing CLAUDE_PTY_SIDECAR — so the next caller can start its own
# claude while ours keeps running.
#
# Stale-lock recovery: holder PID's liveness is checked via kill -0, so a
# SIGKILL'd run doesn't deadlock successors. Tuning knobs:
#   CLAUDE_PTY_LOCK_WAIT_SEC  total wait at acquire (default 600s)
#   CLAUDE_PTY_LOCK_HOLD_SEC  max hold after acquire if the sidecar
#                              never appears (default 10s)
#   CLAUDE_PTY_NO_LOCK=1      skip the lock entirely. Use when the caller
#                              already guarantees serial startup (e.g. it
#                              runs no statusline shim, so the sidecar signal
#                              never arrives and the lock would only ever
#                              release on the hard timeout).
acquire_startup_lock() {
  [ "${CLAUDE_PTY_NO_LOCK:-0}" = "1" ] && return 0
  local wait_max="${CLAUDE_PTY_LOCK_WAIT_SEC:-600}"
  local start_epoch
  start_epoch=$(date +%s)
  local holder=""
  while true; do
    if mkdir "$lock_dir" 2>/dev/null; then
      printf '%s\n' "$$" > "$lock_dir/pid"
      return 0
    fi
    # Stale lock: if the holder PID file is readable and the PID is dead,
    # take ownership. Empty PID file means an in-progress acquire raced;
    # leave it alone and retry.
    if [ -f "$lock_dir/pid" ]; then
      holder=$(cat "$lock_dir/pid" 2>/dev/null || true)
      if [ -n "$holder" ] && ! kill -0 "$holder" 2>/dev/null; then
        rm -rf "$lock_dir" 2>/dev/null || true
        continue
      fi
    fi
    local now
    now=$(date +%s)
    if [ $((now - start_epoch)) -ge "$wait_max" ]; then
      echo "claude-pty: lock wait timeout after ${wait_max}s (holder pid=${holder:-unknown})" >&2
      echo "claude-pty: set CLAUDE_PTY_LOCK_WAIT_SEC to wait longer, or CLAUDE_PTY_NO_LOCK=1 to skip" >&2
      exit 1
    fi
    # Tight poll: typical hold is ~500ms, so a 500ms poll could waste nearly
    # the whole win waiting to notice the lock free. 50ms keeps the acquire
    # gap to one tick.
    sleep 0.05
  done
}

# Background watcher: hand the lock off to the next caller as soon as our
# claude reaches steady state. The signal is the statusline sidecar file
# appearing (statusline.sh writes it ~500ms after first tick). Falls back
# to a hard timeout in case the statusline isn't wired.
release_lock_after_startup() {
  [ "${CLAUDE_PTY_NO_LOCK:-0}" = "1" ] && return 0
  local hold_max="${CLAUDE_PTY_LOCK_HOLD_SEC:-10}"
  local ticks_max=$((hold_max * 10))
  local ticks=0
  while [ "$ticks" -lt "$ticks_max" ]; do
    if [ -f "$CLAUDE_PTY_SIDECAR" ]; then
      break
    fi
    sleep 0.1
    ticks=$((ticks + 1))
  done
  # Only release if the lock is still ours; a SIGKILL'd predecessor could
  # have had its lock stolen by a sibling already.
  local holder=""
  if [ -d "$lock_dir" ]; then
    holder=$(cat "$lock_dir/pid" 2>/dev/null || true)
    if [ "$holder" = "$$" ]; then
      rm -rf "$lock_dir" 2>/dev/null || true
    fi
  fi
}

# Wall-clock timer for duration_ms. If python3 isn't available, emit JSON
# null in the envelope rather than lying with 0.
now_ms() { python3 -c 'import time; print(int(time.time()*1000))' 2>/dev/null || true; }

pty_log() {
  [ -n "${CLAUDE_PTY_DEBUG_LOG:-}" ] \
    && printf '%s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >> "$CLAUDE_PTY_DEBUG_LOG" \
    || true
}

# --- Teammate-aware turn completion -----------------------------------------
#
# The Stop hook rewrites $CLAUDE_PTY_ENVELOPE every time claude finishes a turn,
# and that envelope carries the live `background_tasks` snapshot. The naive
# model — "first envelope appears, kill claude" — is wrong the moment a turn
# spawns background agent work: claude's *visible* turn ends (Stop fires) while
# a subagent/teammate is still running, so killing now murders that teammate
# mid-flight. We have to keep the session alive until the agentic work drains.
#
# How "drained" becomes observable: when a subagent/teammate/workflow finishes,
# it wakes the orchestrator, which produces a fresh turn -> a new Stop -> the
# hook rewrites the envelope, and the finished task has DROPPED OUT of
# background_tasks. So we wait while any awaited-type task is still listed.
#
# Why we await only subagent/teammate/workflow and not every task type: a
# backgrounded *shell* (a dev server, `tail -f`, a watch) completes WITHOUT
# waking the session, so it never produces a draining Stop — the envelope stays
# frozen with that shell "running" indefinitely. Awaiting shells would stall
# every turn that leaves a server running until the timeout. Shells/monitors/
# crons are fire-and-forget here; we finalize as soon as the agentic tasks go.
#
# Set to "background_timeout" by the cap branch below; otherwise stays
# "completed". Consumed by the final envelope's terminal_reason field.
terminal_reason="completed"

# Exit 0 while the latest envelope still lists an in-flight agentic background
# task. Finished tasks drop out of the array, so presence == still running; we
# deliberately don't gate on .status (its non-terminal vocabulary isn't a
# documented, stable set, but the drop-out behavior is observable and reliable).
agentic_tasks_in_flight() {
  [ -f "$CLAUDE_PTY_ENVELOPE" ] || return 1
  jq -e '
    [ .background_tasks[]?
      | select(.type == "subagent" or .type == "teammate" or .type == "workflow") ]
    | length > 0
  ' "$CLAUDE_PTY_ENVELOPE" > /dev/null 2>&1
}

# Liveness predicate for the tmux backend, passed by name to the waiter.
tmux_session_alive() { tmux has-session -t "${CLAUDE_PTY_TMUX_SESSION:-}" 2>/dev/null; }

# Wait for the turn to truly finish: first for the envelope to appear (visible
# turn ended), then for any agentic background work to drain. $1 is the name of
# a predicate function that returns 0 while claude is still alive.
#
# The drain wait is bounded by CLAUDE_PTY_TASK_WAIT_SEC (default 5400s = 1.5h).
# This cap is NOT a "max runtime": agentic work that drains on its own breaks
# the loop the instant its waking Stop lands, no matter how long it ran (10s or
# 3h). The cap only fires on work that CANNOT drain — a teammate parked idle
# waiting for a message this one-shot run will never send, or a genuinely wedged
# task. claude-pty can't distinguish a teammate working hard for an hour from
# one stuck forever (the frozen envelope looks identical either way), so a
# generous wall-clock cap is the only available backstop. 1.5h clears realistic
# long teammate runs while still guaranteeing the run can never hang for good.
wait_for_turn_completion() {
  local alive_check="$1"
  while [ ! -f "$CLAUDE_PTY_ENVELOPE" ] && "$alive_check"; do
    sleep 0.2
  done
  local wait_max="${CLAUDE_PTY_TASK_WAIT_SEC:-5400}"
  local wait_start
  wait_start=$(date +%s)
  while "$alive_check" && agentic_tasks_in_flight; do
    if [ $(( $(date +%s) - wait_start )) -ge "$wait_max" ]; then
      terminal_reason="background_timeout"
      pty_log "agentic background task still in flight after ${wait_max}s; finalizing anyway"
      break
    fi
    sleep 0.3
  done
}

# Subprocess backend — the non-attachable fallback used when there is no tmux
# target (or tmux is unavailable). Without a tty claude runs the turn
# NON-interactively: tools and subagents run inline, it flushes its transcript,
# prints a JSON result, and EXITS on its own. So none of the interactive
# scaffolding applies here — no Stop-hook turn-signal, no statusline sidecar, no
# kill, no agentic-drain wait. `claude -p --output-format=json` already returns
# the bulk of the envelope (cost, turns, usage, modelUsage, terminal_reason,
# fast_mode_state, uuid, is_error...), so we just add the few hook/statusline
# keys it omits and emit one consistent shape.
#
# Why this is the fallback and not an interactive PTY: claude's TUI only
# persists its transcript against a real rendered terminal. tmux provides one; a
# bare/`script` PTY launched headless (no controlling tty) does not, so the
# transcript never flushes there. The subprocess path sidesteps the TUI entirely
# and is therefore correct headless — it just can't be `tmux attach`ed into.
run_subprocess_mode() {
  local out="$tmp_dir/subprocess.json" err="$tmp_dir/subprocess_err" rc
  # Unset the hook env so the global Stop hook no-ops: in -p mode it would only
  # write an envelope we ignore, after a pointless sidecar wait. The `if` keeps a
  # non-zero claude exit from tripping `set -e` before we can dump diagnostics.
  # Redirect stdin from /dev/null: the prompt is a positional arg, and without
  # this claude -p stalls ~3s per turn waiting for piped stdin that never comes.
  if env -u CLAUDE_PTY_ENVELOPE -u CLAUDE_PTY_SIDECAR \
       claude -p --output-format=json "$@" < /dev/null > "$out" 2> "$err"; then
    rc=0
  else
    rc=$?
  fi
  if ! jq -e 'type == "object"' < "$out" > /dev/null 2>&1; then
    {
      echo "claude-pty: subprocess backend produced no JSON result (claude rc=$rc)"
      [ -s "$err" ] && { echo "--- claude stderr (tail) ---"; tail -20 "$err"; }
      [ -s "$out" ] && { echo "--- claude stdout (tail) ---"; tail -c 2000 "$out"; }
      [ -f "$CLAUDE_PTY_DEBUG_LOG" ] && { echo "--- debug log ---"; cat "$CLAUDE_PTY_DEBUG_LOG"; }
    } >&2
    return 1
  fi
  # Merge in the hook/statusline-sourced keys the tmux backend carries but -p
  # omits. Statusline-derived fields (rate_limits, context_window, fast_mode)
  # have no TUI to come from, so statusline stays null; cost/turns are -p's own.
  jq '. + {
    transcript_path: (.transcript_path // null),
    cwd: (.cwd // env.PWD),
    permission_mode: (.permission_mode // null),
    background_tasks: (.background_tasks // []),
    session_crons: (.session_crons // []),
    statusline: (.statusline // null)
  }' < "$out"
}

# Run claude in a detached tmux session, wait for the turn to finish, then reap
# the session. Reached only when an attachable tmux backend was selected (see
# the backend selection below); on a tmux failure it falls back to the
# subprocess backend so a tmux hiccup never costs a turn (losing only attach).
#
# Turn completion is signalled by the Stop hook writing $CLAUDE_PTY_ENVELOPE.
# claude does NOT exit at turn end (the interactive TUI waits for more input), so
# we host it in tmux, poll for the envelope, then kill-session. Owning the reap
# here (vs the old Stop-hook `kill $PPID`) means we know the real session even
# after Claude Code began wrapping hook commands in a shell.
#
# tmux caps a command at a few KB ("command too long"), and the rendered prompt
# plus a full -e environment blow past that, so the only tmux argument is a
# generated launcher: it restores the environment (sourceable `export -p` dump),
# cd's to the workspace, and execs claude with the prompt read from a file.
run_claude_pty() {
  local claude_bin
  claude_bin=$(command -v claude 2>/dev/null || true)
  if [ -n "$claude_bin" ]; then
    local launch="$tmp_dir/launch.sh" promptfile="$tmp_dir/prompt" envfile="$tmp_dir/env.sh"
    printf '%s' "${!#}" > "$promptfile" # last positional arg is the prompt
    export -p > "$envfile"              # full env, safely quoted + sourceable
    {
      printf '#!/usr/bin/env bash\n'
      printf '. %q\n' "$envfile"
      printf 'cd %q 2>/dev/null || true\n' "$PWD"
      printf 'exec %q' "$claude_bin"
      local fl
      for fl in "${@:1:$#-1}"; do printf ' %q' "$fl"; done # flags (all but prompt)
      printf ' "$(cat %q)"\n' "$promptfile"
    } > "$launch"
    chmod +x "$launch"
    tmux kill-session -t "$CLAUDE_PTY_TMUX_SESSION" 2>/dev/null || true
    if tmux new-session -d -c "$PWD" -s "$CLAUDE_PTY_TMUX_SESSION" "$launch" 2> "$tmp_dir/tmux_err"; then
      pty_log "tmux session live: tmux attach -t $CLAUDE_PTY_TMUX_SESSION"
      # Wait for the turn to finish (envelope written + agentic background work
      # drained), or for claude to crash (session vanishes).
      wait_for_turn_completion tmux_session_alive
      # Snapshot the pane's last screen before reaping it, so a resume error or
      # crash message claude printed survives in the debug log instead of dying
      # with the session (tmux mode has no typescript file).
      pty_log "final pane: $(tmux capture-pane -p -t "$CLAUDE_PTY_TMUX_SESSION" 2>/dev/null | grep -v '^[[:space:]]*$' | tail -5 | tr '\n' '|')"
      # kill-session reaps the pane's claude — no orphan, no $PPID guesswork.
      tmux kill-session -t "$CLAUDE_PTY_TMUX_SESSION" 2>/dev/null || true
      pty_log "tmux session closed"
      return 0
    fi
    pty_log "tmux new-session failed ($(tr -d '\n' < "$tmp_dir/tmux_err" 2>/dev/null)); falling back to subprocess backend"
  else
    pty_log "claude not on PATH for tmux exec; falling back to subprocess backend"
  fi
  # No attachable session possible. Emit the subprocess envelope and exit — the
  # tmux-mode enrichment below doesn't apply to a -p result.
  run_subprocess_mode "$@"
  exit $?
}

# Backend selection. An attachable interactive session needs a tmux target, so
# with one (and tmux available) we use the tmux backend. Otherwise the
# subprocess backend: headless and NOT attachable, but it flushes the transcript
# and reports cost/turns directly. The interactive PTY can't flush headless —
# claude's TUI only persists against a real rendered terminal, which tmux
# provides and a bare/`script` PTY does not. The subprocess backend exits on its
# own, so it needs none of the lock / envelope / kill machinery below.
if [ -z "${CLAUDE_PTY_TMUX_SESSION:-}" ] || ! command -v tmux > /dev/null 2>&1; then
  set +e
  run_subprocess_mode "$@"
  rc=$?
  set -e
  exit "$rc"
fi

acquire_startup_lock
if [ "${CLAUDE_PTY_NO_LOCK:-0}" != "1" ]; then
  release_lock_after_startup &
  release_pid=$!
fi

# Measured from just before claude starts (after lock acquire), so lock-wait
# time never inflates duration_ms.
start_ms=$(now_ms)

set +e
run_claude_pty "$@"
rc=$?
set -e

end_ms=$(now_ms)
if [ -n "$start_ms" ] && [ -n "$end_ms" ]; then
  duration_ms=$(( end_ms - start_ms ))
else
  duration_ms=null
fi

if [ ! -f "$CLAUDE_PTY_ENVELOPE" ]; then
  {
    echo "claude-pty: no envelope produced (claude rc=$rc)"
    # tmux mode keeps no typescript; run_claude_pty captures the final pane and
    # its trace into the debug log, which usually names the cause — e.g. a resume
    # of a missing/empty session printing "No conversation found".
    [ -f "$CLAUDE_PTY_DEBUG_LOG" ] && { echo "--- debug log ---"; cat "$CLAUDE_PTY_DEBUG_LOG"; }
  } >&2
  exit 1
fi

# Enrich from the transcript JSONL — best-effort. Do NOT assume it's complete:
# an interactive turn may not have flushed the conversation by the time we kill
# claude (claude buffers it in interactive mode; only `claude -p` writes
# per-event), so this file can hold just metadata. Missing facts stay at the
# defaults below rather than failing the run.
transcript_path=$(jq -r '.transcript_path // empty' "$CLAUDE_PTY_ENVELOPE")
tx_facts='{"num_turns":0,"stop_reason":null,"usage":null,"uuid":null,"modelUsage":{}}'

if [ -n "$transcript_path" ] && [ -f "$transcript_path" ]; then
  tx_facts=$(jq -s '
    (map(select(.type=="assistant"))) as $asst
    | ($asst | last // {}) as $last_asst
    | {
        num_turns:   ($asst | length),
        stop_reason: ($last_asst.message.stop_reason // null),
        usage:       ($last_asst.message.usage // null),
        uuid:        ($last_asst.uuid // $last_asst.message.id // null),
        modelUsage: (
          $asst
          | map({model: (.message.model // "unknown"), u: (.message.usage // {})})
          | group_by(.model)
          | map({
              key: .[0].model,
              value: {
                inputTokens:              (map(.u.input_tokens               // 0) | add),
                outputTokens:             (map(.u.output_tokens              // 0) | add),
                cacheReadInputTokens:     (map(.u.cache_read_input_tokens    // 0) | add),
                cacheCreationInputTokens: (map(.u.cache_creation_input_tokens // 0) | add),
                webSearchRequests:        (map(.u.server_tool_use.web_search_requests // 0) | add)
              }
            })
          | from_entries
        )
      }
  ' "$transcript_path")
fi

# Final envelope: -p shape + statusline subtree + new fields.
jq -n \
  --argjson draft "$(cat "$CLAUDE_PTY_ENVELOPE")" \
  --argjson tx "$tx_facts" \
  --argjson dur "$duration_ms" \
  --arg term "$terminal_reason" '
  $draft + {
    is_error:           false,
    api_error_status:   null,
    stop_reason:        $tx.stop_reason,
    num_turns:          $tx.num_turns,
    duration_ms:        $dur,
    duration_api_ms:    ($draft.statusline.cost.total_api_duration_ms // null),
    ttft_ms:            null,
    total_cost_usd:     ($draft.statusline.cost.total_cost_usd // null),
    usage:              $tx.usage,
    modelUsage:         $tx.modelUsage,
    permission_denials: [],
    terminal_reason:    $term,
    fast_mode_state:    (if ($draft.statusline.fast_mode // false) then "on" else "off" end),
    uuid:               $tx.uuid
  }
'
